# BuddyScript backend env example
# Copy to backend/.env and fill values.

DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Dev-only: allow frontend dev server to call the API
CORS_ALLOW_ALL_ORIGINS=1
# If you prefer locking down CORS, set CORS_ALLOW_ALL_ORIGINS=0 and specify:
# CORS_ALLOWED_ORIGINS=http://localhost:5173

# For cookie/CSRF based flows (optional):
# DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173

# Production DB example (recommended for deploy):
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# If your platform terminates SSL and you want Django to force HTTPS:
# DJANGO_SECURE_SSL_REDIRECT=1
